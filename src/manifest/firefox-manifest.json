{
  "name": "CIDR Match \u2014 IP Range Checker",
  "manifest_version": 3,
  "version": "2.32.1",
  "description": "Shows whether each connection's IP matches your custom CIDR ruleset, and color-codes the toolbar icon. Based on IPvFoo.",
  "homepage_url": "https://github.com/erfnzdeh/ipvfoo-rules",
  "icons": {
    "16": "icon16.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": ["iputil.js", "common.js", "rules.js", "background.js"]
  },
  "_comment_gecko_id": "TODO: 'id' below belongs to upstream IPvFoo. Before publishing this fork to Firefox AMO, replace it with your own add-on ID (e.g. cidr-match@erfnzdeh).",
  "browser_specific_settings": {
    "gecko": {
      "id": "cidr-match@erfnzdeh",
      "strict_min_version": "115.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  },
  "page_action": {
    "default_icon": {
      "16": "icon16_transparent.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  },
  "permissions": [
    "contextMenus",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
