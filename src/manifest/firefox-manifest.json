{
  "name": "IPvFoo+Rules",
  "manifest_version": 3,
  "version": "2.32.1",
  "description": "IPvFoo fork: shows whether each row's IP matches your custom CIDR ruleset (\u2714/\u2716), with the toolbar icon color-coded by the main page IP's match status.",
  "homepage_url": "https://github.com/pmarks-net/ipvfoo",
  "icons": {
    "16": "icon16.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": ["iputil.js", "common.js", "rules.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ipvfoo@pmarks.net",
      "strict_min_version": "115.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  },
  "page_action": {
    "default_icon": {
      "16": "icon16_transparent.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  },
  "permissions": [
    "contextMenus",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
